# Shopify App Credentials (from partners.shopify.com)
SHOPIFY_API_KEY=your_client_id_here
SHOPIFY_API_SECRET=your_api_secret_here

# Comma-separated list of required OAuth scopes
SCOPES=read_customers,write_customers,read_orders

# Your deployed app URL (update after first Vercel deploy)
SHOPIFY_APP_URL=https://your-app.vercel.app

# Database
# Development: SQLite (local file)
DATABASE_URL="file:./dev.db"
# Production: PostgreSQL (Neon, Supabase, Vercel Postgres, etc.)
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Optional: restrict to a custom shop domain during development
# SHOP_CUSTOM_DOMAIN=mystore.myshopify.com

# GDPR Note: This app stores customer email addresses and names for giveaway
# entries. Ensure your store's privacy policy reflects this data collection.
# Entries are deleted when a giveaway is deleted (CASCADE).
